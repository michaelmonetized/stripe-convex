{
  "name": "stripe-convex",
  "version": "0.1.0",
  "description": "A reusable Stripe + Convex payment system with email-based tracking, cart functionality, and TypeScript-first coupon system",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./convex": {
      "import": "./dist/convex/index.js",
      "types": "./dist/convex/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "stripe",
    "convex",
    "payments",
    "subscriptions",
    "checkout",
    "ecommerce",
    "cart",
    "coupons",
    "react",
    "typescript",
    "saas",
    "billing"
  ],
  "author": "Michael Hurley <michael@hurleyus.com>",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelmonetized/stripe-convex.git"
  },
  "bugs": {
    "url": "https://github.com/michaelmonetized/stripe-convex/issues"
  },
  "homepage": "https://github.com/michaelmonetized/stripe-convex#readme",
  "peerDependencies": {
    "convex": ">=1.0.0",
    "react": ">=18.0.0",
    "stripe": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
