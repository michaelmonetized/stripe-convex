{
  "name": "stripe-convex",
  "version": "0.1.0",
  "description": "Reusable Stripe + Convex payment system with email-based tracking",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./convex": {
      "import": "./dist/convex/index.js",
      "types": "./dist/convex/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    }
  },
  "files": [
    "dist",
    "convex"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "stripe",
    "convex",
    "payments",
    "subscriptions",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "convex": ">=1.0.0",
    "react": ">=18.0.0",
    "stripe": ">=14.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "convex": "^1.31.7",
    "react": "^19.2.4",
    "stripe": "^20.3.0"
  }
}
